{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/tests/**/*",
      "!{projectRoot}/jest.config.cjs"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/package-lock.json",
      "{workspaceRoot}/tsconfig.base.json",
      "{workspaceRoot}/biome.json"
    ]
  },
  "targetDefaults": {
    "build": { "cache": true, "inputs": ["production", "^production"] },
    "lint": { "cache": true, "inputs": ["default", "^default"] },
    "test": { "cache": true, "inputs": ["default", "^production"] },
    "test-coverage": { "cache": true, "inputs": ["default", "^production"] },
    "typecheck": { "cache": true, "inputs": ["production", "^production"] }
  }
}
