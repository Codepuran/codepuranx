{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true, "defaultBranch": "dev" },
  "files": {
    "includes": ["**", "!dist", "!**/dist", "!coverage", "!**/coverage", "!.nx", "!node_modules", "!package-lock.json"]
  },
  "formatter": { "enabled": true, "expand": "never", "indentStyle": "space", "indentWidth": 2, "lineWidth": 120 },
  "javascript": {
    "formatter": { "expand": "never", "quoteStyle": "single", "semicolons": "always", "trailingCommas": "es5" }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noAdjacentSpacesInRegex": "error",
        "noCommaOperator": "error",
        "noExtraBooleanCast": "error",
        "noForEach": "error",
        "noStaticOnlyClass": "error",
        "noUselessCatch": "error",
        "noUselessConstructor": "error",
        "noUselessSwitchCase": "error",
        "noUselessThisAlias": "error",
        "noUselessTypeConstraint": "error",
        "noUselessUndefinedInitialization": "error",
        "useDateNow": "error",
        "useFlatMap": "error",
        "useLiteralKeys": "error",
        "useOptionalChain": "error",
        "useWhile": "error"
      },
      "correctness": {
        "noInvalidUseBeforeDeclaration": "error",
        "noUnusedVariables": "error",
        "useValidForDirection": "error"
      },
      "security": { "noGlobalEval": "error" },
      "style": {
        "noInferrableTypes": "error",
        "noNamespace": "error",
        "noUselessElse": "error",
        "noYodaExpression": "error",
        "useAsConstAssertion": "error",
        "useConsistentBuiltinInstantiation": "error",
        "useConst": "error",
        "useExplicitLengthCheck": "error",
        "useFilenamingConvention": {
          "level": "error",
          "options": { "requireAscii": true, "filenameCases": ["kebab-case"] }
        },
        "useForOf": "error",
        "useLiteralEnumMembers": "error",
        "useNodejsImportProtocol": "error",
        "useNumberNamespace": "error",
        "useShorthandFunctionType": "error",
        "useThrowNewError": "error",
        "useThrowOnlyError": "error"
      },
      "suspicious": {
        "noAssignInExpressions": "error",
        "noConsole": "error",
        "noDoubleEquals": "error",
        "noEmptyInterface": "error",
        "noExplicitAny": "error",
        "noExtraNonNullAssertion": "error",
        "noFallthroughSwitchClause": "error",
        "noPrototypeBuiltins": "error",
        "noThenProperty": "error",
        "noUnsafeDeclarationMerging": "error",
        "useErrorMessage": "error",
        "useNamespaceKeyword": "error",
        "useNumberToFixedDigitsArgument": "error"
      }
    }
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "overrides": [
    { "includes": ["apps/backend/scripts/**/*"], "linter": { "rules": { "suspicious": { "noConsole": "off" } } } }
  ]
}
