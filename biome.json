{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "files": {
    "includes": [
      "**",
      "!dist/**",
      "!**/dist/**",
      "!coverage/**",
      "!**/coverage/**",
      "!.nx/**",
      "!node_modules/**",
      "!package-lock.json"
    ]
  },
  "formatter": { "enabled": true, "expand": "never", "indentStyle": "space", "indentWidth": 2, "lineWidth": 120 },
  "javascript": {
    "formatter": { "expand": "never", "quoteStyle": "single", "semicolons": "always", "trailingCommas": "es5" }
  },
  "linter": { "enabled": true, "rules": { "recommended": true } },
  "assist": { "actions": { "source": { "organizeImports": "on" } } }
}
