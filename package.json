{
  "name": "codepuranx",
  "version": "1.0.0",
  "private": true,
  "description": "This repository will contain a Fastify-based TypeScript API designed for high performance, DynamoDB persistence, and AWS Lambda readiness.",
  "type": "module",
  "directories": { "doc": "docs" },
  "workspaces": ["apps/*"],
  "scripts": {
    "build": "nx build backend",
    "check": "nx run-many -t typecheck lint test build",
    "dynamo:check": "nx run backend:dynamo-check",
    "dynamo:setup": "nx run backend:dynamo-setup",
    "dev": "nx serve backend",
    "format": "biome format --write .",
    "lint": "nx lint backend",
    "start": "nx run backend:start",
    "test": "nx test backend",
    "test:coverage": "nx run backend:test-coverage",
    "typecheck": "nx typecheck backend"
  },
  "engines": { "node": ">=24 <25", "npm": ">=11" },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1045.0",
    "@aws-sdk/lib-dynamodb": "^3.1045.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "dotenv": "^17.4.2",
    "fastify": "~5.8.0",
    "fastify-plugin": "^5.1.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.12.3",
    "jest": "^29.7.0",
    "json-schema-to-ts": "^3.1.1",
    "nx": "^22.7.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
